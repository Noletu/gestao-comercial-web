# Env do backend (apps/api). Copie para apps/api/.env e ajuste localmente.
# NUNCA comite segredos reais — apps/api/.env está no .gitignore.
NODE_ENV=development
PORT=3001

# ── Banco de dados ───────────────────────────────────────────────────────────
# Dois roles propositais (defesa em profundidade do multi-tenant):
#  - DATABASE_URL        -> role app_user (SEM superusuário): usado pelo runtime.
#                           Como não é dono das tabelas nem superusuário, o
#                           Row-Level Security é SEMPRE aplicado a ele.
#  - DIRECT_DATABASE_URL -> role postgres (owner/superusuário): usado só por
#                           `prisma migrate` e pelo seed, que precisam ignorar RLS.
# Porta 5432 = Docker (docker-compose.yml). O role app_user e sua senha são
# criados pela migration inicial (SQL de RLS).
DATABASE_URL="postgresql://app_user:app_user_pw@localhost:5432/gestao_comercial?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestao_comercial?schema=public"

# ── Criptografia ─────────────────────────────────────────────────────────────
# Chave AES-256-GCM, base64 de 32 bytes. Gere a sua com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="troque-por-uma-chave-base64-de-32-bytes"

# ── Better Auth (autenticação self-hosted) ──────────────────────────────────
# Segredo de assinatura de sessões/tokens (min. 32 chars). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="troque-por-um-segredo-de-32-chars-ou-mais"
# URL pública da própria API e origem do front (CORS / trustedOrigins).
BETTER_AUTH_URL="http://localhost:3001"
WEB_ORIGIN="http://localhost:3000"

# Seed do casal: e-mails e senha inicial. NUNCA comite senhas reais (repo público).
SEED_OWNER1_EMAIL="owner1@example.com"
SEED_OWNER2_EMAIL="owner2@example.com"
SEED_OWNER_PASSWORD="defina-uma-senha-forte-localmente"

# ── Nuvemshop — Épico 1, OAuth (issue #12) ───────────────────────────────────
# client_id É o app_id do app no portal (34160). client_secret é SEGREDO e só é
# usado server-side na troca do code por token — NUNCA exposto ao front nem
# comitado (repo público). Pegue ambos no painel do app na Nuvemshop.
NUVEMSHOP_CLIENT_ID=34160
NUVEMSHOP_CLIENT_SECRET="cole-o-client-secret-do-app-aqui"
# URL pública do NOSSO callback. Em dev é a URL do túnel (ngrok/cloudflared);
# em prod, a do Railway. Deve ser IDÊNTICA à "URL de redirecionamento"
# cadastrada no portal do app. Configurável por env para não hardcodar.
NUVEMSHOP_REDIRECT_URI="http://localhost:3001/api/nuvemshop/callback"
# Versão da API de recursos e User-Agent (obrigatório em toda chamada). Têm
# default no código; sobrescreva só se precisar.
# NUVEMSHOP_API_VERSION=2025-03
# NUVEMSHOP_USER_AGENT="GestaoComercial (regotodigital@gmail.com)"
